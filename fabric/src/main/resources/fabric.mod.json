{
  "schemaVersion": 1,
  "id": "chattabs-reloaded",
  "version": "${version}",

  "name": "ChatTabs Reloaded",
  "description": "Adds customizable, user-configurable chat tabs and filters — ChatTabs Reloaded (fork by Wakcedon)",
  "authors": [
    "Wakcedon",
    "Gri11edHam"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/chat-tabs",
    "sources": "https://github.com/Wakcedon/ChatTabs",
    "issues": "https://github.com/Wakcedon/ChatTabs/issues"
  },

  "license": "GPL-3.0",
  "icon": "assets/chattabs/icon.png",

  "environment": "client",
  "entrypoints": {
    "client": ["net.wakcedon.chattabsreloaded.client.ChatTabsClient"],
    "main": ["net.wakcedon.chattabsreloaded.fabric.FabricEntrypoint"],
    "modmenu": ["net.wakcedon.chattabsreloaded.config.ModMenuIntegration"]
  },

  "mixins": [
    "chattabs.mixins.json"
  ],

  "accessWidener": "chattabs.accesswidener",

  "depends": {
    "fabric-api": "*",
    "fabricloader": ">=${loader_version}",
    "minecraft": ">=${minecraft_version}",
    "cloth-config": ">=11.0.98"
  }
}
